# Firebase Console → Project settings → General → Your apps → Web app config
# Restart `npm run dev` after editing.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
# e.g. nomad-815ab.firebasestorage.app (Firebase Console → Storage)
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional; matches GA4 in Console (not used by this app — Auth/Firestore only)
VITE_FIREBASE_MEASUREMENT_ID=

# Optional E.164 support WhatsApp e.g. +919876543210 (Shop Profile CTA)
VITE_SUPPORT_WHATSAPP=

# UPI ID for Plans & Billing (e.g. yourname@paytm)
VITE_BILLING_UPI_ID=

# Buyer storefront (public menu / ordering). Optional override; defaults to https://fafo-buyer.vercel.app
# Must be the buyer app only — do NOT set this to the seller dashboard URL (fafo-seller.vercel.app).
# Prefer:
VITE_BUYER_PUBLIC_BASE=
# Legacy alias (ignored if it points at seller, localhost, or placeholders)
# VITE_BUYER_STOREFRONT_BASE=
